// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  models      HardwareModel[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HardwareModel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  errorCodes  ErrorCode[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brandId])
}

model ErrorCode {
  id              String   @id @default(cuid())
  slug            String   @unique
  code            String
  description     String
  severity        String   // e.g. "Critical", "Warning", "Info"
  solution        String
  hardwareModelId String
  hardwareModel   HardwareModel @relation(fields: [hardwareModelId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([hardwareModelId])
}

model GlossaryTerm {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  definition  String
  markdown    String
  category    String
  publishAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([publishAt])
}
